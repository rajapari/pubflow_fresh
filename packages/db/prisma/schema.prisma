generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum UserRole {
  SUPER_ADMIN
  EDITOR_IN_CHIEF
  SECTION_EDITOR
  COPY_EDITOR
  ARTWORK_EDITOR
  TYPESETTER
  PROOF_READER
  PEER_REVIEWER
  AUTHOR
  READER
}

enum PublicationType {
  JOURNAL
  BOOK
  BOOK_SERIES
  PROCEEDINGS
}

enum PublicationStatus {
  ACTIVE
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  DESK_REVIEW
  PEER_REVIEW
  REVISION_REQUIRED
  REVISED
  ACCEPTED
  COPY_EDITING
  ARTWORK_PROCESSING
  TYPESETTING
  PROOF_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  WITHDRAWN
}

enum ManuscriptFormat {
  DOCX
  LATEX
  MARKDOWN
  ODT
  RTF
  PDF
  ZIP
}

enum ReviewStatus {
  INVITED
  ACCEPTED
  DECLINED
  IN_PROGRESS
  SUBMITTED
  OVERDUE
}

enum ReviewRecommendation {
  ACCEPT
  MINOR_REVISION
  MAJOR_REVISION
  REJECT
}

enum Decision {
  ACCEPT
  MINOR_REVISION
  MAJOR_REVISION
  REJECT
  DESK_REJECT
}

enum AssetType {
  FIGURE
  TABLE
  SUPPLEMENTARY
  GRAPHICAL_ABSTRACT
  COVER
}

enum StyleManual {
  INHOUSE
  APA7
  CHICAGO17
  AMA11
  MLA9
  VANCOUVER
  IEEE
  CSE
  HARVARD
}

enum TemplateSourceFormat {
  IDML
  INDD
  LATEX
  PDF
}

enum TemplateStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
}

enum ProofCorrectionKind {
  INSERT
  DELETE
  REPLACE
  MOVE
  QUERY_ANSWER
  COMMENT
}

enum ProofCorrectionStatus {
  OPEN
  ACCEPTED
  REJECTED
  APPLIED
}

enum ProofQueryStatus {
  OPEN
  ANSWERED
  RESOLVED
}

enum AssetStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum ColorMode {
  RGB
  CMYK
  GRAYSCALE
  LAB
}

enum OutputFormat {
  PDF_PRINT
  PDF_WEB
  EPUB
  HTML
  JATS_XML
  DOCX
  BIBTEX
  JSON_LD
}

enum LayoutEngine {
  LATEX
  SCRIBUS
  PANDOC
  WEASYPRINT
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum ProofReviewStatus {
  OPEN
  IN_PROGRESS
  APPROVED
  REJECTED
  NEEDS_REVISION
  SUBMITTED
}

enum CopyEditStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Tenant {
  id               String       @id @default(uuid())
  name             String
  slug             String       @unique
  plan             Plan         @default(STARTER)
  status           TenantStatus @default(ACTIVE)
  stripeCustomerId String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users          User[]
  publishers     Publisher[]
  publications   Publication[]
  submissions    Submission[]
  subscriptions  Subscription[]
  settings       TenantSettings?
  styleProfiles  StyleProfile[]
  layoutTemplates LayoutTemplate[]

  @@map("tenants")
}

// A publishing house (Springer, Elsevier, T&F, …). Publications (journals /
// books) belong to a publisher; the submission wizard cascades
// publisher → journal, and cloud-storage folders are derived from this
// hierarchy: {tenant}/{publisher}/{journal}/{submission}/…
model Publisher {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publications Publication[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("publishers")
}

model TenantSettings {
  id                    String  @id @default(uuid())
  tenantId              String  @unique
  logoUrl               String?
  primaryColor          String  @default("#534AB7")
  defaultCitationStyle  String  @default("apa")
  enablePeerReview      Boolean @default(true)
  enableDoiRegistration Boolean @default(false)
  doiPrefix             String?
  crossrefLoginId       String?
  crossrefLoginPassword String?
  pmcFtpHost            String?
  pmcFtpUsername        String?
  pmcFtpPassword        String?
  pmcFtpPath            String?
  enablePrintOnDemand   Boolean @default(false)
  luluClientKey         String?
  luluClientSecret      String?
  luluPodPackageId      String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id          String     @id @default(uuid())
  tenantId    String
  keycloakId  String     @unique
  email       String
  firstName   String?
  lastName    String?
  orcid       String?
  affiliation String?
  role        UserRole   @default(AUTHOR)
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions        Submission[]        @relation("SubmissionAuthor")
  assignedReviews    Review[]            @relation("ReviewerAssignment")
  editorialDecisions EditorialDecision[]
  uploadedAssets     Asset[]

  proofReviews       ProofReview[]
  copyEdits          CopyEdit[]    @relation("CopyEditorAssignment")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([keycloakId])
  @@map("users")
}

model Publication {
  id                   String            @id @default(uuid())
  tenantId             String
  publisherId          String?
  title                String
  type                 PublicationType   @default(JOURNAL)
  issn                 String?
  isbn                 String?
  description          String?
  coverUrl             String?
  submissionGuidelines String?
  reviewerInstructions String?
  status               PublicationStatus @default(ACTIVE)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publisher       Publisher?       @relation(fields: [publisherId], references: [id])
  submissions     Submission[]
  issues          Issue[]
  styleProfiles   StyleProfile[]
  layoutTemplates LayoutTemplate[]

  @@unique([tenantId, title])
  @@index([tenantId])
  @@index([publisherId])
  @@map("publications")
}

model Issue {
  id            String    @id @default(uuid())
  publicationId String
  volume        Int?
  number        Int?
  year          Int
  title         String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  publication Publication  @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("issues")
}

model Submission {
  id            String           @id @default(uuid())
  tenantId      String
  publicationId String
  issueId       String?
  authorId      String
  title         String
  abstract      String?
  keywords      String[]
  coAuthors     Json             @default("[]")
  status        SubmissionStatus @default(DRAFT)
  // Peer-review revision rounds completed (each MINOR/MAJOR_REVISION decision
  // increments). Hard cap 3: afterwards the editor must accept or reject.
  revisionRound Int              @default(0)
  doi           String?
  submittedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  tenant      Tenant      @relation(fields: [tenantId],      references: [id], onDelete: Cascade)
  publication Publication @relation(fields: [publicationId], references: [id])
  issue       Issue?      @relation(fields: [issueId],       references: [id])
  author      User        @relation("SubmissionAuthor", fields: [authorId], references: [id])

  manuscripts  Manuscript[]
  reviews      Review[]
  proofReviews ProofReview[]
  copyEdits    CopyEdit[]
  assets       Asset[]
  outputs      Output[]
  decisions    EditorialDecision[]
  workflowLogs WorkflowLog[]

  @@index([tenantId])
  @@index([authorId])
  @@index([status])
  @@map("submissions")
}

model Manuscript {
  id            String           @id @default(uuid())
  submissionId  String
  format        ManuscriptFormat
  minioPath     String
  minioKey      String
  fileSizeBytes Int
  version       Int              @default(1)
  isLatest      Boolean          @default(true)
  pandocJson    Json?
  uploadedAt    DateTime         @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("manuscripts")
}

model Review {
  id                String                @id @default(uuid())
  submissionId      String
  reviewerId        String
  round             Int                   @default(1)
  status            ReviewStatus          @default(INVITED)
  recommendation    ReviewRecommendation?
  comments          String?
  confidentialNotes String?
  dueAt              DateTime?
  submittedAt        DateTime?
  lastReminderSentAt DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation("ReviewerAssignment", fields: [reviewerId], references: [id])

  @@index([submissionId])
  @@index([status, dueAt])
  @@map("reviews")
}

model EditorialDecision {
  id           String   @id @default(uuid())
  submissionId String
  editorId     String
  decision     Decision
  notes        String?
  createdAt    DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  editor     User       @relation(fields: [editorId],     references: [id])

  @@map("editorial_decisions")
}

model ProofReview {
  id           String            @id @default(uuid())
  submissionId String
  outputId     String?
  reviewerId   String
  round        Int               @default(1)
  status       ProofReviewStatus @default(OPEN)
  comments     String?
  annotations  Json              @default("{}")
  submittedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  submission  Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  output      Output?           @relation(fields: [outputId], references: [id])
  reviewer    User              @relation(fields: [reviewerId], references: [id])
  queries     ProofQuery[]
  corrections ProofCorrection[]

  @@index([submissionId])
  @@map("proof_reviews")
}

// A query raised by a copyeditor / typesetter on a proof, answered by the
// author or editor in the online proof workbench.
model ProofQuery {
  id            String           @id @default(uuid())
  proofReviewId String
  submissionId  String
  // Sequential label shown on the proof, e.g. "Q1", "Q2".
  label         String
  raisedBy      String?
  question      String
  // 1-based page + normalized position for the on-page pin.
  page          Int?
  posX          Float?
  posY          Float?
  status        ProofQueryStatus @default(OPEN)
  answer        String?
  answeredById  String?
  answeredAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  proofReview ProofReview @relation(fields: [proofReviewId], references: [id], onDelete: Cascade)

  @@index([proofReviewId])
  @@index([submissionId])
  @@map("proof_queries")
}

// A correction marked on a proof by an author or editor. Structured so the
// Correction Applier bot can patch the source and re-typeset.
model ProofCorrection {
  id            String                @id @default(uuid())
  proofReviewId String
  submissionId  String
  markedById    String
  kind          ProofCorrectionKind
  page          Int?
  posX          Float?
  posY          Float?
  // Original text targeted (for REPLACE/DELETE) and the new/inserted text.
  targetText    String?
  newText       String?
  note          String?
  status        ProofCorrectionStatus @default(OPEN)
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  proofReview ProofReview @relation(fields: [proofReviewId], references: [id], onDelete: Cascade)

  @@index([proofReviewId])
  @@index([submissionId])
  @@map("proof_corrections")
}

// A reusable copyediting style profile. In-house style is just an INHOUSE
// profile; publisher manuals (APA/Chicago/AMA…) are separate profiles.
// tenantId scopes ownership; publicationId (optional) narrows it to one journal.
model StyleProfile {
  id            String      @id @default(uuid())
  tenantId      String
  publicationId String?
  name          String
  manual        StyleManual @default(INHOUSE)
  // CSL style key used by the reference formatter (citeproc/Pandoc).
  cslStyle      String      @default("apa")
  // LanguageTool rule-pack id and AI copyeditor prompt id for this manual.
  rulesetKey    String?
  promptKey     String?
  // In-house overlay instructions applied on top of the base manual.
  houseRules    String[]    @default([])
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publication Publication? @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([publicationId])
  @@map("style_profiles")
}

// A publisher layout (InDesign IDML / LaTeX) ported into a reusable Scribus
// or LaTeX template asset used by the typesetting stage.
model LayoutTemplate {
  id            String               @id @default(uuid())
  tenantId      String
  publicationId String?
  name          String
  sourceFormat  TemplateSourceFormat
  targetEngine  LayoutEngine
  // Original publisher file and the generated Scribus/LaTeX template.
  sourceMinioKey    String
  generatedMinioKey String?
  // Extracted geometry / styles / fonts / swatches from the source layout.
  spec          Json                 @default("{}")
  status        TemplateStatus       @default(DRAFT)
  errorMessage  String?
  version       Int                  @default(1)
  isDefault     Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publication Publication? @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([publicationId])
  @@map("layout_templates")
}

model CopyEdit {
  id           String         @id @default(uuid())
  submissionId String
  editorId     String
  status       CopyEditStatus @default(ASSIGNED)
  editedKey    String?
  comments     String?
  editorNotes  String?
  // Style-manual which the automated copyedit bot ran against.
  styleManual  StyleManual?
  // Output of the automated style/language bot: counts + suggestions report.
  botReport    Json?
  assignedAt   DateTime       @default(now())
  submittedAt  DateTime?
  approvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  editor     User       @relation("CopyEditorAssignment", fields: [editorId], references: [id])

  @@index([submissionId])
  @@map("copy_edits")
}

model Asset {
  id                String      @id @default(uuid())
  submissionId      String
  uploadedById      String
  filename          String
  assetType         AssetType
  minioKey          String
  minioKeyProcessed String?
  mimeType          String
  fileSizeBytes     Int
  dpi               Int?
  width             Int?
  height            Int?
  colorMode         ColorMode?
  iccProfile        String?
  figureLabel       String?
  altText           String?
  caption           String?
  status            AssetStatus @default(PENDING)
  metadata          Json        @default("{}")
  uploadedAt        DateTime    @default(now())
  processedAt       DateTime?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation(fields: [uploadedById], references: [id])

  @@index([submissionId])
  @@map("assets")
}

model Output {
  id            String       @id @default(uuid())
  submissionId  String
  format        OutputFormat
  engine        LayoutEngine
  minioKey      String
  fileSizeBytes Int?
  version       Int          @default(1)
  jobId         String?
  status        JobStatus    @default(QUEUED)
  errorMessage  String?
  generatedAt   DateTime?
  createdAt     DateTime     @default(now())

  // Preflight Bot (PDF/X conformance, embedded fonts, trim/bleed boxes).
  // NULL until the bot runs (or for non-PDF_PRINT formats, which never get
  // one). Shape: { status: 'pending'|'error'|'pass'|'warn'|'fail', checks: [...],
  // error?: string, ranAt: ISO string } — one field, matching the
  // CopyEdit.botReport / LayoutTemplate.spec precedent elsewhere in this schema.
  preflightReport Json?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  proofReviews ProofReview[]

  @@index([submissionId])
  @@map("outputs")
}

model WorkflowLog {
  id           String            @id @default(uuid())
  submissionId String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  performedBy  String?
  note         String?
  metadata     Json              @default("{}")
  createdAt    DateTime          @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("workflow_logs")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String
  stripeSubscriptionId String             @unique
  stripePriceId        String
  plan                 Plan
  status               SubscriptionStatus
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}
