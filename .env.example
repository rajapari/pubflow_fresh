# ============================================================
# PubFlow — Environment Variables
# ------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file: copy .env.example .env   (Windows)
#                    cp .env.example .env      (Mac/Linux)
# 2. Replace every value that says CHANGE_ME
# 3. Generate secrets by running in terminal:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# ── Keycloak (Login system) ───────────────────────────────
# This is the admin password for Keycloak — remember it!
KEYCLOAK_ADMIN_PASSWORD=Admin@PubFlow2025
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK

# ── OnlyOffice (Document editor) ─────────────────────────
# Generate with the same command above
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE

# ── Meilisearch (Search engine) ───────────────────────────
# Generate with the same command above
MEILISEARCH_API_KEY=CHANGE_ME_MEILISEARCH

# ── Penpot (Design tool) ──────────────────────────────────
# Generate with the same command above
PENPOT_SECRET_KEY=CHANGE_ME_PENPOT

# ── Stripe (Payments) ─────────────────────────────────────
# Leave these as-is for now — we set up Stripe later
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_STARTER_PRICE_ID=price_CHANGE_ME
STRIPE_PRO_PRICE_ID=price_CHANGE_ME

# ── CrossRef (DOI registration) ───────────────────────────
# Leave blank for now — set up in Phase 4
CROSSREF_USERNAME=
CROSSREF_PASSWORD=

# ── App URLs ──────────────────────────────────────────────
# Do not change these for local development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
