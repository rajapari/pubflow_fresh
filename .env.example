# ============================================================
# PubFlow — Environment Variables (single source of truth)
# ------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file: copy .env.example .env   (Windows)
#                    cp .env.example .env      (Mac/Linux)
# 2. Replace every value that says CHANGE_ME
# 3. Generate secrets by running in terminal:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT: this ONE file feeds BOTH the Node apps (tsx --env-file)
# AND the Docker containers. Always start Docker via `pnpm docker:dev`
# from the repo root — it passes this file to docker compose with
# --env-file, so app-side and container-side secrets can never drift.
# ============================================================

# ── Core services ─────────────────────────────────────────
# 127.0.0.1, not localhost: on Windows, localhost resolves to IPv6 ::1 first,
# which can silently connect to a different service than the Docker port map.
# POSTGRES_PASSWORD feeds the postgres/keycloak/penpot containers directly
# (docker-compose.yml) — it MUST match the password embedded in DATABASE_URL
# below, or the app and the database container disagree on the credential.
POSTGRES_PASSWORD=pubflow_secret
DATABASE_URL=postgresql://pubflow:pubflow_secret@127.0.0.1:5432/pubflow
REDIS_URL=redis://127.0.0.1:6379/0

# ── Keycloak (Login system) ───────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pubflow
KEYCLOAK_CLIENT_ID=pubflow-api
# This is the admin password for Keycloak — remember it!
KEYCLOAK_ADMIN_PASSWORD=Admin@PubFlow2025
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=pubflow
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=pubflow-web

# ── MinIO (File storage) ──────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=pubflow-files
MINIO_ACCESS_KEY=pubflow_minio
MINIO_SECRET_KEY=pubflow_minio_secret

# ── OnlyOffice (Document editor) ─────────────────────────
# REQUIRED — docker compose refuses to start OnlyOffice without it, and the
# API verifies at startup that both sides hold the same value. Generate with
# the crypto command above.
ONLYOFFICE_JWT_SECRET=CHANGE_ME_ONLYOFFICE
ONLYOFFICE_URL=http://localhost:8081
# Hostname the OnlyOffice CONTAINER uses to reach MinIO (Docker service name
# locally; in k8s leave unset to fall back to MINIO_ENDPOINT).
ONLYOFFICE_MINIO_HOST=minio
# URL the OnlyOffice container uses to reach the API for save callbacks
# (host.docker.internal on Windows/Mac Docker Desktop).
ONLYOFFICE_CALLBACK_URL=http://host.docker.internal:3001

# ── Meilisearch (Search engine) ───────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=CHANGE_ME_MEILISEARCH

# ── Penpot (Design tool) ──────────────────────────────────
PENPOT_SECRET_KEY=CHANGE_ME_PENPOT

# ── Email (Mailpit locally) ───────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@pubflow.local

# ── Stripe (Payments) ─────────────────────────────────────
# Leave these as-is for now — we set up Stripe later
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PROFESSIONAL=price_CHANGE_ME_PROFESSIONAL
STRIPE_PRICE_ENTERPRISE=price_CHANGE_ME_ENTERPRISE

# ── CrossRef (DOI registration) ───────────────────────────
CROSSREF_LOGIN_ID=
CROSSREF_LOGIN_PASSWORD=
CROSSREF_DEPOSITOR_EMAIL=noreply@pubflow.local
CROSSREF_TEST_MODE=true

# ── PubMed / PMC delivery (optional) ──────────────────────
PMC_FTP_HOST=
PMC_FTP_USERNAME=
PMC_FTP_PASSWORD=
PMC_FTP_PATH=/incoming

# ── Lulu print-on-demand (optional) ───────────────────────
LULU_CLIENT_KEY=
LULU_CLIENT_SECRET=
LULU_POD_PACKAGE_ID=0600X0900BWSTDSS060UW444MXX

# ── Language & conversion services ────────────────────────
LANGUAGETOOL_URL=http://localhost:8082
PANDOC_SERVICE_URL=http://localhost:4000
LATEX_SERVICE_URL=http://localhost:5001

# ── App URLs ──────────────────────────────────────────────
# Do not change these for local development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
